# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to version control

# Cerebras (free tier — cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Anthropic Claude (optional — only needed if using Claude provider) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (optional — only needed if using OpenAI provider) ──
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Gemini (AI Studio) (optional — only needed if using Gemini provider) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Active AI provider ──
# Which provider to use by default. Options: cerebras | claude | openai | gemini
AI_PROVIDER=cerebras

# Default models (overridden by dashboard model selector)
AI_MODEL_CEREBRAS=llama-4-scout-17b-16e-instruct
AI_MODEL_CLAUDE=claude-sonnet-4-6
AI_MODEL_OPENAI=gpt-4o
AI_MODEL_GEMINI=gemini-2.5-flash

# Instagram Graph API
# Get from: developers.facebook.com → Your App → Instagram Basic Display or Graph API
IG_ACCESS_TOKEN=your_long_lived_access_token_here
IG_USER_ID=your_instagram_business_user_id_here

# Google Cloud (for Imagen 3 / Google Flow)
# Create a project at console.cloud.google.com, enable Vertex AI API
GOOGLE_PROJECT_ID=your_gcp_project_id
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json

# Google Sheets (for calendar + KPI storage)
# Share both sheets with your service account email
SHEETS_CREDS_FILE=sheets-credentials.json
SHEETS_CALENDAR_ID=your_google_sheet_id_for_calendar
SHEETS_KPI_ID=your_google_sheet_id_for_kpi

# Flask
SECRET_KEY=change-this-to-a-random-secret-string
DEBUG=true
PORT=5000

# App defaults (used in Cerebras prompts)
DEFAULT_NICHE=Food & Lifestyle
DEFAULT_TONE=warm & friendly
DEFAULT_LOCATION=Nairobi
